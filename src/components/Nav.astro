---
import { SITE_NAME, ACQUISITION_EMAIL, acquisitionMailto } from '../lib/constants';

const mailto = acquisitionMailto();
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <div class="flex items-center gap-x-3">
        <a href="/" class="flex items-center gap-x-3" aria-label={SITE_NAME}>
          <div class="w-9 h-9 rounded-2xl bg-gradient-to-br from-[#22f5ff] via-[#a855f7] to-[#22f5ff] p-px">
            <div class="w-full h-full bg-dark rounded-2xl flex items-center justify-center">
              <span class="text-[#22f5ff] text-lg font-bold tracking-tighter">SAF</span>
            </div>
          </div>
          <div>
            <span class="font-display text-2xl font-semibold tracking-tighter text-white">secureaiframeworks</span>
            <span class="text-[#22f5ff] font-display text-2xl font-semibold tracking-tighter">.cloud</span>
          </div>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-x-9 text-sm font-medium">
        <a href="#positioning" class="nav-link text-white/80 hover:text-white">The Opportunity</a>
        <a href="#why" class="nav-link text-white/80 hover:text-white">Why This Domain</a>
        <a href="#uses" class="nav-link text-white/80 hover:text-white">Ideal For</a>
      </div>

      <!-- CTA Buttons -->
      <div class="flex items-center gap-x-3">
        <a href={mailto}
           class="hidden sm:inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold rounded-2xl border border-white/20 hover:bg-white/5 transition-colors text-white">
          Inquire
        </a>
        <a href={mailto}
           class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold rounded-2xl bg-white text-dark hover:bg-white/90 transition-all active:scale-[0.985]">
          Secure Now
        </a>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn"
                class="md:hidden w-10 h-10 flex items-center justify-center text-white/70 hover:text-white transition-colors"
                aria-label="Toggle menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>

<!-- Mobile Menu -->
<div id="mobile-menu" class="hidden md:hidden fixed inset-0 z-40 bg-dark pt-20">
  <div class="px-6 py-8 flex flex-col gap-y-6 text-lg font-medium">
    <a href="#positioning" class="mobile-nav-link py-2 text-white/80">The Opportunity</a>
    <a href="#why" class="mobile-nav-link py-2 text-white/80">Why This Domain</a>
    <a href="#uses" class="mobile-nav-link py-2 text-white/80">Ideal For</a>
    <div class="pt-4 border-t border-white/10">
      <a href={mailto} class="block w-full text-center py-3.5 rounded-2xl bg-white text-dark font-semibold">Secure This Domain</a>
    </div>
  </div>
</nav>

<script>
  // Navbar scroll behavior
  function initNavbar() {
    const navbar = document.getElementById('navbar');
    if (!navbar) return;

    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar.style.background = 'rgba(10, 10, 15, 0.95)';
        navbar.style.backdropFilter = 'blur(20px)';
        navbar.style.borderBottom = '1px solid rgba(255, 255, 255, 0.08)';
      } else {
        navbar.style.background = '';
        navbar.style.backdropFilter = '';
        navbar.style.borderBottom = '';
      }
    });
  }

  // Mobile menu toggle
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      const icon = btn.querySelector('svg');
      if (icon) {
        if (!menu.classList.contains('hidden')) {
          icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6h12v12" />`;
        } else {
          icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />`;
        }
      }
    });

    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        if (icon) {
          icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />`;
        }
      });
    });
  }

  // Smooth scroll
  function initSmoothScroll() {
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        const targetId = this.getAttribute('href')?.substring(1);
        const target = document.getElementById(targetId || '');
        if (target) {
          e.preventDefault();
          const offset = 80;
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          window.scrollBy(0, -offset);
        }
      });
    });
  }

  // Keyboard accessibility
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      const menu = document.getElementById('mobile-menu');
      if (menu && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
      }
    }
  });

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => { initNavbar(); initMobileMenu(); initSmoothScroll(); });
  } else {
    initNavbar(); initMobileMenu(); initSmoothScroll();
  }
</script>
