---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE_NAME, ACQUISITION_EMAIL, HERO_IMAGE_URL, acquisitionMailto } from '../lib/constants';

const mailto = acquisitionMailto();
const title = `${SITE_NAME} — Secure AI Frameworks — Premium Domain`;
const description = 'Acquire secureaiframeworks.cloud — the definitive, category-owning premium .cloud domain for secure AI frameworks, enterprise AI security, guardrails, compliance, and trustworthy AI infrastructure.';
---

<BaseLayout title={title} description={description}>
  <Nav />

  <!-- Hero Section -->
  <header class="hero-bg min-h-[100dvh] flex items-center relative pt-20"
    style={`background-image: linear-gradient(rgba(10, 10, 15, 0.68), rgba(10, 10, 15, 0.75)), url(${HERO_IMAGE_URL}); background-size: cover; background-position: center;`}>
    <div class="max-w-5xl mx-auto px-6 pb-16 pt-12 md:pt-8 text-center relative z-10">
      <!-- Premium Badge -->
      <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-full border border-white/10 bg-white/5 mb-8">
        <div class="w-1.5 h-1.5 bg-[#22f5ff] rounded-full animate-pulse"></div>
        <span class="text-xs font-semibold tracking-[1.5px] text-white/80">ENTERPRISE AI SECURITY DOMAIN</span>
      </div>

      <!-- Domain Name -->
      <h1 class="domain-text font-display mb-3 tracking-[-0.07em]">
        secureaiframeworks.cloud
      </h1>

      <!-- Tagline -->
      <p class="max-w-2xl mx-auto text-3xl md:text-4xl font-light tracking-tight text-white/90 mb-4">
        The foundation for<br />
        trustworthy AI at scale.
      </p>

      <p class="max-w-lg mx-auto text-xl text-white/70 mb-10">
        Secure frameworks are no longer optional.<br />
        This is the domain that owns the category.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={mailto}
           class="group w-full sm:w-auto inline-flex items-center justify-center gap-x-3 px-9 py-4 text-lg font-semibold rounded-3xl bg-gradient-to-r from-[#22f5ff] to-[#a855f7] text-dark hover:brightness-105 active:scale-[0.985] transition-all shadow-xl shadow-[#22f5ff]/20">
          <span>Secure This Asset</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.25" d="M14 5l7 7-7 7m-4-7h11" />
          </svg>
        </a>
        <a href="#positioning"
           class="w-full sm:w-auto inline-flex items-center justify-center gap-x-2 px-8 py-4 text-lg font-medium rounded-3xl border border-white/20 hover:bg-white/5 transition-colors text-white">
          Explore the Opportunity
        </a>
      </div>

      <div class="mt-12 flex items-center justify-center gap-x-8 text-xs text-white/50">
        <div class="flex items-center gap-x-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7" />
          </svg>
          <span>Instant Transfer</span>
        </div>
        <div>Escrow Protected</div>
        <div>High-Intent Buyers</div>
      </div>
    </div>

    <!-- Subtle scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 hidden md:block">
      <div class="flex flex-col items-center gap-y-1 text-[10px] tracking-widest text-white/40">
        <div>SCROLL TO BEGIN</div>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7" />
        </svg>
      </div>
    </div>
  </header>

  <!-- The Opportunity / Positioning Section -->
  <section id="positioning" class="max-w-5xl mx-auto px-6 pt-20 pb-16">
    <div class="grid md:grid-cols-12 gap-x-12 items-center">
      <!-- Left content -->
      <div class="md:col-span-7">
        <div class="inline-block px-3.5 py-1 rounded-full bg-white/5 text-xs tracking-[1.5px] font-medium text-white/60 mb-4">THE OPPORTUNITY</div>

        <h2 class="section-header tracking-[-0.04em] leading-none mb-7">
          AI without security<br />
          is not deployable.
        </h2>

        <div class="space-y-6 text-lg text-white/80 max-w-[42ch]">
          <p>
            Enterprises are racing to adopt AI, but security, compliance, and trust remain the biggest blockers. Secure AI frameworks — guardrails, safety layers, governance tools, and robust infrastructure — are now essential infrastructure.
          </p>
          <p>
            <span class="font-semibold text-white">secureaiframeworks.cloud</span> is the clearest, most authoritative domain in this critical and fast-growing category.
          </p>
          <p class="text-white/70">
            It signals expertise, credibility, and immediate relevance to CISOs, AI leaders, and enterprise buyers.
          </p>
        </div>
      </div>

      <!-- Right visual card -->
      <div class="md:col-span-5 mt-10 md:mt-0">
        <div class="glass rounded-3xl p-9 md:p-10 border border-white/10">
          <div class="text-center">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-[#22f5ff20] to-[#a855f720] border border-white/20 mb-6">
              <span class="font-display text-sm font-bold tracking-[-0.5px] gradient-text">SECURE AI</span>
            </div>

            <div class="space-y-1">
              <div class="text-3xl font-bold tracking-tighter">Frameworks</div>
              <div class="text-sm text-white/60 tracking-[2px] mt-1">SECURITY · GOVERNANCE · TRUST</div>
            </div>

            <div class="mt-8 pt-6 border-t border-white/10 text-sm text-white/60 leading-relaxed">
              The domain that enterprises<br />
              will search for first.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why This Domain Section -->
  <section id="why" class="bg-white/5 border-y border-white/10 py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <div class="inline-block px-4 py-1 rounded-full bg-white/5 text-xs tracking-[1.5px] font-medium text-white/60 mb-3">WHY THIS DOMAIN</div>
        <h2 class="section-header tracking-[-0.03em]">Built for high-intent buyers.</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        <!-- Card 1 -->
        <div class="modern-card glass rounded-3xl p-8 border border-white/10 hover:border-[#22f5ff]/30">
          <div class="w-11 h-11 rounded-2xl bg-[#22f5ff]/10 flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#22f5ff]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 8.944 11.922" />
            </svg>
          </div>
          <h3 class="font-semibold text-xl tracking-tight mb-3">Category-Owning Name</h3>
          <p class="text-white/70 leading-relaxed"><span class="font-medium">secureaiframeworks.cloud</span> directly and clearly describes the solution space. It is the natural domain buyers will search for or type when looking for secure AI infrastructure.</p>
        </div>

        <!-- Card 2 -->
        <div class="modern-card glass rounded-3xl p-8 border border-white/10 hover:border-[#a855f7]/30">
          <div class="w-11 h-11 rounded-2xl bg-[#a855f7]/10 flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#a855f7]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2.009 2.009 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-semibold text-xl tracking-tight mb-3">Premium Professional Branding</h3>
          <p class="text-white/70 leading-relaxed">hello@secureaiframeworks.cloud and similar addresses instantly convey credibility and specialization to enterprise buyers, investors, and partners.</p>
        </div>

        <!-- Card 3 -->
        <div class="modern-card glass rounded-3xl p-8 border border-white/10 hover:border-emerald-400/30">
          <div class="w-11 h-11 rounded-2xl bg-emerald-400/10 flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-semibold text-xl tracking-tight mb-3">High Commercial Intent</h3>
          <p class="text-white/70 leading-relaxed">Buyers in this space (CISOs, AI platform leads, enterprise architects) have high budgets and clear intent. This domain aligns perfectly with their search behavior and needs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ideal For / Use Cases -->
  <section id="uses" class="max-w-6xl mx-auto px-6 py-20">
    <div class="max-w-2xl mb-12">
      <div class="inline-block px-3.5 py-1 rounded-full bg-white/5 text-xs tracking-[1.5px] font-medium text-white/60 mb-4">IDEAL FOR</div>
      <h2 class="section-header tracking-[-0.035em] leading-none">The natural home for leaders in AI security.</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      <div class="group p-7 rounded-3xl border border-white/10 hover:border-white/20 transition-colors bg-white/[0.015]">
        <div class="font-mono text-xs tracking-widest text-[#22f5ff] mb-2">01</div>
        <div class="font-semibold text-lg mb-2 group-hover:text-[#22f5ff] transition-colors">AI Security Platform</div>
        <p class="text-sm text-white/60">Flagship domain for a company building guardrails, safety layers, red-teaming tools, or runtime security for AI systems.</p>
      </div>

      <div class="group p-7 rounded-3xl border border-white/10 hover:border-white/20 transition-colors bg-white/[0.015]">
        <div class="font-mono text-xs tracking-widest text-[#22f5ff] mb-2">02</div>
        <div class="font-semibold text-lg mb-2 group-hover:text-[#22f5ff] transition-colors">Enterprise AI Governance</div>
        <p class="text-sm text-white/60">Ideal for platforms helping large organizations manage AI risk, compliance, model auditing, and responsible deployment at scale.</p>
      </div>

      <div class="group p-7 rounded-3xl border border-white/10 hover:border-white/20 transition-colors bg-white/[0.015]">
        <div class="font-mono text-xs tracking-widest text-[#22f5ff] mb-2">03</div>
        <div class="font-semibold text-lg mb-2 group-hover:text-[#22f5ff] transition-colors">Secure AI Development Frameworks</div>
        <p class="text-sm text-white/60">Perfect for open-source or commercial frameworks that help developers build secure, robust, and auditable AI systems by default.</p>
      </div>

      <div class="group p-7 rounded-3xl border border-white/10 hover:border-white/20 transition-colors bg-white/[0.015]">
        <div class="font-mono text-xs tracking-widest text-[#22f5ff] mb-2">04</div>
        <div class="font-semibold text-lg mb-2 group-hover:text-[#22f5ff] transition-colors">Cloud AI Infrastructure Security</div>
        <p class="text-sm text-white/60">Strong fit for companies providing secure hosting, inference platforms, or cloud-native security layers for AI workloads.</p>
      </div>

      <div class="group p-7 rounded-3xl border border-white/10 hover:border-white/20 transition-colors bg-white/[0.015]">
        <div class="font-mono text-xs tracking-widest text-[#22f5ff] mb-2">05</div>
        <div class="font-semibold text-lg mb-2 group-hover:text-[#22f5ff] transition-colors">AI Compliance &amp; Risk Solutions</div>
        <p class="text-sm text-white/60">Excellent for tools and services focused on regulatory compliance, bias detection, model cards, and enterprise AI risk management.</p>
      </div>

      <div class="group p-7 rounded-3xl border border-white/10 hover:border-white/20 transition-colors bg-white/[0.015]">
        <div class="font-mono text-xs tracking-widest text-[#22f5ff] mb-2">06</div>
        <div class="font-semibold text-lg mb-2 group-hover:text-[#22f5ff] transition-colors">Thought Leadership &amp; Research</div>
        <p class="text-sm text-white/60">Authoritative domain for research organizations, publications, or communities focused on secure, safe, and trustworthy AI.</p>
      </div>
    </div>
  </section>

  <!-- Poignant Closer -->
  <div class="max-w-3xl mx-auto px-6 text-center py-8 border-y border-white/10">
    <p class="text-2xl md:text-3xl font-light tracking-tight text-white/90">
      The organizations that win with AI<br />
      will be the ones that secure it first.
    </p>
  </div>

  <!-- Final CTA Section -->
  <section id="acquire" class="max-w-4xl mx-auto px-6 py-20">
    <div class="text-center mb-10">
      <div class="inline-block px-4 py-1 rounded-full bg-emerald-400/10 text-emerald-400 text-xs tracking-[1.5px] font-semibold mb-4">PREMIUM ACQUISITION</div>
      <h2 class="section-header tracking-[-0.03em]">A strategic asset in a critical category.</h2>
    </div>

    <div class="glass rounded-3xl p-10 md:p-14 border border-white/10">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-y-8">
        <div>
          <div class="flex items-baseline gap-x-2">
            <span class="text-6xl md:text-7xl font-semibold tracking-tighter">$14,997</span>
            <span class="text-white/50 text-xl">USD</span>
          </div>
          <p class="mt-1 text-white/60">One-time acquisition · Full ownership &amp; instant transfer</p>

          <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm">
            <div class="flex items-center gap-x-2 text-white/70">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
              <span>Clean title, ready for transfer</span>
            </div>
            <div class="flex items-center gap-x-2 text-white/70">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
              <span>Escrow.com protected transaction</span>
            </div>
          </div>
        </div>

        <div class="md:text-right">
          <a href={mailto}
             class="inline-flex w-full md:w-auto items-center justify-center px-10 py-4 rounded-3xl bg-gradient-to-r from-[#22f5ff] to-[#a855f7] font-semibold text-dark text-lg active:scale-[0.985] transition-all hover:brightness-105">
            Begin Acquisition
          </a>
          <p class="text-xs text-white/50 mt-3 md:mt-2">Serious buyers only. Flexible terms available.</p>
        </div>
      </div>
    </div>

    <div class="mt-8 text-center">
      <p class="text-xs text-white/50 max-w-md mx-auto">
        Descriptive, high-intent domains in the AI security and infrastructure space are increasingly valuable.
        This asset offers immediate relevance and long-term strategic positioning.
      </p>
    </div>
  </section>

  <Footer />
</BaseLayout>
